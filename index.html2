            <!-- FVG List -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i class="fas fa-bolt"></i> Fair Value Gaps</div>
                </div>

                <div class="fvg-item fvg-bullish">
                    <span style="color: var(--success); font-weight: 800;">Bullish FVG</span>
                    <span style="font-family: monospace;">2,341.20 - 2,342.80</span>
                </div>

                <div class="fvg-item fvg-bearish">
                    <span style="color: var(--danger); font-weight: 800;">Bearish FVG</span>
                    <span style="font-family: monospace;">2,346.50 - 2,345.80</span>
                </div>

                <div class="fvg-item fvg-bullish">
                    <span style="color: var(--success); font-weight: 800;">Bullish FVG</span>
                    <span style="font-family: monospace;">2,339.00 - 2,340.10</span>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Germany Time
        function updateGermanyTime() {
            const now = new Date();
            const germanyTime = new Date(now.toLocaleString("en-US", {timeZone: "Europe/Berlin"}));
            const hours = String(germanyTime.getHours()).padStart(2, '0');
            const minutes = String(germanyTime.getMinutes()).padStart(2, '0');
            const seconds = String(germanyTime.getSeconds()).padStart(2, '0');
            document.getElementById('germany-time').textContent = `${hours}:${minutes}:${seconds}`;

            const day = String(germanyTime.getDate()).padStart(2, '0');
            const month = String(germanyTime.getMonth() + 1).padStart(2, '0');
            const year = germanyTime.getFullYear();
            document.getElementById('current-date').textContent = `${day}/${month}/${year}`;
        }
        setInterval(updateGermanyTime, 1000);
        updateGermanyTime();

        // Price simulation
        let currentPrice = 2345.67;
        function updatePrice() {
            const change = (Math.random() - 0.48) * 0.5;
            currentPrice += change;
            document.getElementById('gold-price').textContent = currentPrice.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",");

            const changePercent = ((currentPrice - 2333.22) / 2333.22 * 100).toFixed(2);
            const changeEl = document.getElementById('price-change');
            if (changePercent >= 0) {
                changeEl.textContent = `+${changePercent}%`;
                changeEl.className = 'ticker-change change-up';
            } else {
                changeEl.textContent = `${changePercent}%`;
                changeEl.className = 'ticker-change change-down';
            }
        }
        setInterval(updatePrice, 2000);

        // Countdown timer
        let countdownSeconds = 272; // 4:32
        function updateCountdown() {
            countdownSeconds--;
            if (countdownSeconds < 0) countdownSeconds = 600;
            const m = String(Math.floor(countdownSeconds / 60)).padStart(2, '0');
            const s = String(countdownSeconds % 60).padStart(2, '0');
            document.getElementById('countdown-timer').textContent = `${m}:${s}`;
        }
        setInterval(updateCountdown, 1000);

        // Chart Setup
        const chartElement = document.getElementById('chart');
        const chart = LightweightCharts.createChart(chartElement, {
            layout: {
                background: { color: '#1a1f2e' },
                textColor: '#94a3b8',
            },
            grid: {
                vertLines: { color: '#2d3748', style: 2 },
                horzLines: { color: '#2d3748', style: 2 },
            },
            crosshair: {
                mode: LightweightCharts.CrosshairMode.Normal,
                vertLine: { color: '#ffd700', width: 1, style: 2 },
                horzLine: { color: '#ffd700', width: 1, style: 2 },
            },
            rightPriceScale: {
                borderColor: '#2d3748',
            },
            timeScale: {
                borderColor: '#2d3748',
                timeVisible: true,
                secondsVisible: false,
            },
        });

        // Generate realistic gold data
        function generateData() {
            const data = [];
            let price = 2330;
            const now = new Date();
            now.setHours(now.getHours() - 24);

            for (let i = 0; i < 288; i++) { // 24 hours of 5-min candles
                const time = new Date(now.getTime() + i * 5 * 60000);
                const volatility = 2.5;
                const trend = Math.sin(i / 30) * 5 + i * 0.05;

                const open = price + (Math.random() - 0.5) * volatility;
                const close = open + (Math.random() - 0.5) * volatility + trend * 0.1;
                const high = Math.max(open, close) + Math.random() * volatility * 0.5;
                const low = Math.min(open, close) - Math.random() * volatility * 0.5;

                data.push({
                    time: time.getTime() / 1000,
                    open: open,
                    high: high,
                    low: low,
                    close: close
                });
                price = close;
            }
            return data;
        }

        const candleSeries = chart.addCandlestickSeries({
            upColor: '#10b981',
            downColor: '#ef4444',
            borderUpColor: '#10b981',
            borderDownColor: '#ef4444',
            wickUpColor: '#10b981',
            wickDownColor: '#ef4444',
        });

        const data = generateData();
        candleSeries.setData(data);

        // Add EMA lines
        function calculateEMA(data, period) {
            const k = 2 / (period + 1);
            const emaData = [];
            let ema = data[0].close;

            for (let i = 0; i < data.length; i++) {
                ema = data[i].close * k + ema * (1 - k);
                emaData.push({ time: data[i].time, value: ema });
            }
            return emaData;
        }

        const ema20 = chart.addLineSeries({ color: '#3b82f6', lineWidth: 2, title: 'EMA 20' });
        const ema50 = chart.addLineSeries({ color: '#f59e0b', lineWidth: 2, title: 'EMA 50' });
        const ema200 = chart.addLineSeries({ color: '#ec4899', lineWidth: 2, title: 'EMA 200' });

        ema20.setData(calculateEMA(data, 20));
        ema50.setData(calculateEMA(data, 50));
        ema200.setData(calculateEMA(data, 200));

        // Support/Resistance lines
        const supportLine = chart.addLineSeries({ 
            color: '#10b981', 
            lineWidth: 1, 
            lineStyle: 2,
            title: 'Support'
        });
        supportLine.setData([
            { time: data[0].time, value: 2340 },
            { time: data[data.length-1].time, value: 2340 }
        ]);

        const resistanceLine = chart.addLineSeries({ 
            color: '#ef4444', 
            lineWidth: 1, 
            lineStyle: 2,
            title: 'Resistance'
        });
        resistanceLine.setData([
            { time: data[0].time, value: 2350 },
            { time: data[data.length-1].time, value: 2350 }
        ]);

        chart.timeScale().fitContent();

        // Timeframe buttons
        document.querySelectorAll('.tf-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.tf-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                // In real app, this would fetch new data for the timeframe
            });
        });

        // Tool buttons
        document.querySelectorAll('.tool-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                this.classList.toggle('active');
            });
        });

        // Dynamic sentiment marker
        setInterval(() => {
            const sentiment = 40 + Math.random() * 40;
            document.getElementById('sentiment-marker').style.left = sentiment + '%';
        }, 5000);

        // Resize handler
        window.addEventListener('resize', () => {
            chart.applyOptions({ width: chartElement.clientWidth, height: chartElement.clientHeight });
        });
    </script>
</body>
</html>
