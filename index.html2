<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gold Pro Analytics | تحليل الذهب الاحترافي</title>
    <script src="https://unpkg.com/lightweight-charts@4.1.0/dist/lightweight-charts.standalone.production.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0a0e1a;
            --bg-secondary: #111827;
            --bg-card: #1a1f2e;
            --bg-hover: #252b3d;
            --border-color: #2d3748;
            --gold-primary: #ffd700;
            --gold-secondary: #ffb800;
            --gold-dark: #b8860b;
            --text-primary: #e2e8f0;
            --text-secondary: #94a3b8;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --info: #3b82f6;
            --buy-color: #10b981;
            --sell-color: #ef4444;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Tajawal', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            overflow-x: hidden;
        }

        /* Header */
        .header {
            background: linear-gradient(135deg, #1a1f2e 0%, #0f172a 100%);
            border-bottom: 2px solid var(--gold-dark);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 4px 20px rgba(255, 215, 0, 0.1);
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-icon {
            width: 45px;
            height: 45px;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            color: #000;
            font-weight: 900;
            box-shadow: 0 0 20px rgba(255, 215, 0, 0.4);
        }

        .logo-text {
            font-size: 26px;
            font-weight: 900;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.5px;
        }

        .header-info {
            display: flex;
            gap: 30px;
            align-items: center;
        }

        .time-box {
            text-align: center;
            padding: 8px 20px;
            background: rgba(255, 215, 0, 0.1);
            border: 1px solid var(--gold-dark);
            border-radius: 10px;
        }

        .time-label {
            font-size: 11px;
            color: var(--gold-secondary);
            font-weight: 700;
            margin-bottom: 2px;
        }

        .time-value {
            font-size: 18px;
            font-weight: 800;
            color: var(--gold-primary);
            font-family: 'Courier New', monospace;
        }

        .price-ticker {
            display: flex;
            gap: 25px;
            align-items: center;
        }

        .ticker-item {
            text-align: center;
        }

        .ticker-label {
            font-size: 11px;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .ticker-value {
            font-size: 24px;
            font-weight: 900;
            color: var(--gold-primary);
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
        }

        .ticker-change {
            font-size: 14px;
            font-weight: 700;
            padding: 2px 8px;
            border-radius: 4px;
            margin-top: 2px;
        }

        .change-up { color: var(--success); background: rgba(16, 185, 129, 0.1); }
        .change-down { color: var(--danger); background: rgba(239, 68, 68, 0.1); }

        /* Main Layout */
        .main-container {
            display: grid;
            grid-template-columns: 280px 1fr 320px;
            gap: 15px;
            padding: 15px;
            max-width: 1920px;
            margin: 0 auto;
        }

        /* Cards */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 15px;
            transition: all 0.3s ease;
        }

        .card:hover {
            border-color: var(--gold-dark);
            box-shadow: 0 4px 20px rgba(255, 215, 0, 0.05);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            padding-bottom: 12px;
            border-bottom: 1px solid var(--border-color);
        }

        .card-title {
            font-size: 16px;
            font-weight: 800;
            color: var(--gold-primary);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .card-title i {
            color: var(--gold-secondary);
        }

        /* Timeframes */
        .timeframe-buttons {
            display: flex;
            gap: 5px;
            flex-wrap: wrap;
        }

        .tf-btn {
            padding: 6px 14px;
            border: 1px solid var(--border-color);
            background: var(--bg-secondary);
            color: var(--text-secondary);
            border-radius: 6px;
            cursor: pointer;
            font-family: 'Tajawal', sans-serif;
            font-weight: 700;
            font-size: 13px;
            transition: all 0.2s;
        }

        .tf-btn:hover, .tf-btn.active {
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            color: #000;
            border-color: var(--gold-primary);
            box-shadow: 0 0 15px rgba(255, 215, 0, 0.3);
        }

        /* Chart Container */
        .chart-container {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 15px;
            height: 600px;
            position: relative;
        }

        .chart-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .chart-title {
            font-size: 18px;
            font-weight: 900;
            color: var(--gold-primary);
        }

        .chart-tools {
            display: flex;
            gap: 10px;
        }

        .tool-btn {
            padding: 6px 12px;
            background: var(--bg-secondary);
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            border-radius: 6px;
            cursor: pointer;
            font-size: 12px;
            font-weight: 700;
            transition: all 0.2s;
        }

        .tool-btn:hover {
            border-color: var(--gold-primary);
            color: var(--gold-primary);
        }

        .tool-btn.active {
            background: rgba(255, 215, 0, 0.1);
            color: var(--gold-primary);
            border-color: var(--gold-primary);
        }

        #chart {
            width: 100%;
            height: calc(100% - 50px);
            border-radius: 8px;
        }

        /* Signal Cards */
        .signal-card {
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(16, 185, 129, 0.05));
            border: 1px solid rgba(16, 185, 129, 0.3);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 10px;
            position: relative;
            overflow: hidden;
        }

        .signal-card.sell {
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(239, 68, 68, 0.05));
            border-color: rgba(239, 68, 68, 0.3);
        }

        .signal-card.neutral {
            background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(245, 158, 11, 0.05));
            border-color: rgba(245, 158, 11, 0.3);
        }

        .signal-badge {
            position: absolute;
            top: 10px;
            left: 10px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .badge-buy { background: var(--success); color: white; }
        .badge-sell { background: var(--danger); color: white; }
        .badge-neutral { background: var(--warning); color: white; }

        .signal-timeframe {
            font-size: 13px;
            color: var(--text-secondary);
            margin-bottom: 8px;
            font-weight: 700;
        }

        .signal-price {
            font-size: 20px;
            font-weight: 900;
            margin-bottom: 10px;
        }

        .signal-details {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 8px;
            margin-top: 10px;
        }

        .detail-box {
            background: rgba(0,0,0,0.2);
            padding: 8px;
            border-radius: 6px;
            text-align: center;
        }

        .detail-label {
            font-size: 10px;
            color: var(--text-secondary);
            margin-bottom: 2px;
        }

        .detail-value {
            font-size: 14px;
            font-weight: 800;
        }

        .detail-value.entry { color: var(--info); }
        .detail-value.sl { color: var(--danger); }
        .detail-value.tp { color: var(--success); }

        .signal-strength {
            margin-top: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .strength-bar {
            flex: 1;
            height: 6px;
            background: rgba(255,255,255,0.1);
            border-radius: 3px;
            overflow: hidden;
        }

        .strength-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 0.5s ease;
        }

        .strength-text {
            font-size: 12px;
            font-weight: 800;
            min-width: 40px;
        }

        /* Analysis Section */
        .analysis-item {
            padding: 12px;
            background: var(--bg-secondary);
            border-radius: 8px;
            margin-bottom: 8px;
            border-right: 3px solid var(--gold-dark);
        }

        .analysis-title {
            font-size: 13px;
            font-weight: 800;
            color: var(--gold-primary);
            margin-bottom: 5px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .analysis-text {
            font-size: 12px;
            color: var(--text-secondary);
            line-height: 1.6;
        }

        .indicator-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 0;
            border-bottom: 1px solid var(--border-color);
        }

        .indicator-row:last-child {
            border-bottom: none;
        }

        .indicator-name {
            font-size: 13px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .indicator-value {
            font-size: 13px;
            font-weight: 800;
            padding: 3px 10px;
            border-radius: 4px;
        }

        .ind-buy { color: var(--success); background: rgba(16, 185, 129, 0.1); }
        .ind-sell { color: var(--danger); background: rgba(239, 68, 68, 0.1); }
        .ind-neutral { color: var(--warning); background: rgba(245, 158, 11, 0.1); }

        /* News Section */
        .news-item {
            padding: 12px;
            background: var(--bg-secondary);
            border-radius: 8px;
            margin-bottom: 10px;
            border-right: 3px solid var(--info);
            transition: all 0.2s;
            cursor: pointer;
        }

        .news-item:hover {
            background: var(--bg-hover);
            transform: translateX(-3px);
        }

        .news-item.high-impact {
            border-right-color: var(--danger);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.2); }
            50% { box-shadow: 0 0 0 8px rgba(239, 68, 68, 0); }
        }

        .news-time {
            font-size: 11px;
            color: var(--gold-secondary);
            font-weight: 700;
            margin-bottom: 4px;
        }

        .news-title {
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 4px;
            line-height: 1.4;
        }

        .news-impact {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 800;
            margin-top: 4px;
        }

        .impact-high { background: rgba(239, 68, 68, 0.2); color: var(--danger); }
        .impact-medium { background: rgba(245, 158, 11, 0.2); color: var(--warning); }
        .impact-low { background: rgba(59, 130, 246, 0.2); color: var(--info); }

        /* Liquidity Zones */
        .liquidity-zone {
            padding: 10px;
            background: var(--bg-secondary);
            border-radius: 8px;
            margin-bottom: 8px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .zone-label {
            font-size: 12px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .zone-price {
            font-family: 'Courier New', monospace;
            font-weight: 800;
            font-size: 14px;
        }

        .zone-buy { color: var(--success); }
        .zone-sell { color: var(--danger); }

        /* Order Blocks */
        .ob-item {
            padding: 10px;
            background: var(--bg-secondary);
            border-radius: 8px;
            margin-bottom: 8px;
            border-right: 3px solid var(--gold-dark);
        }

        .ob-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 6px;
        }

        .ob-type {
            font-size: 12px;
            font-weight: 800;
            color: var(--gold-primary);
        }

        .ob-strength {
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 4px;
            background: rgba(255, 215, 0, 0.1);
            color: var(--gold-secondary);
        }

        .ob-range {
            font-size: 12px;
            color: var(--text-secondary);
            font-family: 'Courier New', monospace;
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-primary);
        }

        ::-webkit-scrollbar-thumb {
            background: var(--gold-dark);
            border-radius: 3px;
        }

        /* Responsive */
        @media (max-width: 1400px) {
            .main-container {
                grid-template-columns: 260px 1fr 300px;
            }
        }

        @media (max-width: 1200px) {
            .main-container {
                grid-template-columns: 1fr;
            }
            .sidebar-left, .sidebar-right {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 15px;
            }
        }

        /* Market Sentiment */
        .sentiment-gauge {
            width: 100%;
            height: 30px;
            background: linear-gradient(to right, var(--danger), var(--warning), var(--success));
            border-radius: 15px;
            position: relative;
            margin: 15px 0;
            overflow: hidden;
        }

        .gauge-marker {
            position: absolute;
            top: -5px;
            width: 4px;
            height: 40px;
            background: white;
            box-shadow: 0 0 10px rgba(0,0,0,0.5);
            transition: left 0.5s ease;
        }

        .gauge-labels {
            display: flex;
            justify-content: space-between;
            font-size: 11px;
            font-weight: 800;
            color: var(--text-secondary);
        }

        /* FVG */
        .fvg-item {
            padding: 8px;
            background: var(--bg-secondary);
            border-radius: 6px;
            margin-bottom: 6px;
            font-size: 12px;
            display: flex;
            justify-content: space-between;
        }

        .fvg-bullish { border-right: 3px solid var(--success); }
        .fvg-bearish { border-right: 3px solid var(--danger); }

        /* Countdown */
        .countdown-box {
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(239, 68, 68, 0.05));
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
            text-align: center;
        }

        .countdown-title {
            font-size: 13px;
            color: var(--danger);
            font-weight: 800;
            margin-bottom: 8px;
        }

        .countdown-timer {
            font-size: 28px;
            font-weight: 900;
            color: var(--danger);
            font-family: 'Courier New', monospace;
            text-shadow: 0 0 10px rgba(239, 68, 68, 0.3);
        }

        .countdown-event {
            font-size: 12px;
            color: var(--text-secondary);
            margin-top: 5px;
        }

        /* Loading Animation */
        .loading-bar {
            width: 100%;
            height: 3px;
            background: var(--bg-secondary);
            position: relative;
            overflow: hidden;
            border-radius: 2px;
        }

        .loading-progress {
            position: absolute;
            top: 0;
            right: 0;
            height: 100%;
            background: linear-gradient(90deg, var(--gold-primary), var(--gold-secondary));
            animation: loading 2s ease-in-out infinite;
            border-radius: 2px;
        }

        @keyframes loading {
            0% { width: 0%; right: 100%; }
            50% { width: 100%; right: 0; }
            100% { width: 0%; right: 0; }
        }
    </style>
<base target="_blank">
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="logo">
            <div class="logo-icon">Au</div>
            <div class="logo-text">GOLD PRO ANALYTICS</div>
        </div>

        <div class="header-info">
            <div class="time-box">
                <div class="time-label">الوقت في ألمانيا</div>
                <div class="time-value" id="germany-time">--:--:--</div>
            </div>
            <div class="time-box">
                <div class="time-label">التاريخ</div>
                <div class="time-value" id="current-date">--/--/----</div>
            </div>
            <div class="price-ticker">
                <div class="ticker-item">
                    <div class="ticker-label">XAU/USD</div>
                    <div class="ticker-value" id="gold-price">2,345.67</div>
                    <div class="ticker-change change-up" id="price-change">+12.45 (+0.53%)</div>
                </div>
            </div>
        </div>
    </header>

    <div class="main-container">
        <!-- Left Sidebar -->
        <div class="sidebar-left">
            <!-- Timeframes -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i class="fas fa-clock"></i> الفريمات الزمنية</div>
                </div>
                <div class="timeframe-buttons">
                    <button class="tf-btn" data-tf="1">1د</button>
                    <button class="tf-btn active" data-tf="5">5د</button>
                    <button class="tf-btn" data-tf="15">15د</button>
                    <button class="tf-btn" data-tf="60">1س</button>
                    <button class="tf-btn" data-tf="240">4س</button>
                    <button class="tf-btn" data-tf="D">يومي</button>
                </div>
            </div>

            <!-- Market Sentiment -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i class="fas fa-balance-scale"></i> مؤشر المشاعر</div>
                </div>
                <div class="sentiment-gauge">
                    <div class="gauge-marker" id="sentiment-marker" style="left: 65%;"></div>
                </div>
                <div class="gauge-labels">
                    <span>بيع قوي</span>
                    <span>محايد</span>
                    <span>شراء قوي</span>
                </div>
                <div style="text-align: center; margin-top: 10px; font-size: 14px; font-weight: 800; color: var(--success);">
                    اتجاه صاعد قوي - 65%
                </div>
            </div>

            <!-- Technical Indicators -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i class="fas fa-chart-line"></i> المؤشرات الفنية</div>
                </div>
                <div class="indicator-row">
                    <div class="indicator-name"><i class="fas fa-wave-square" style="color: #8b5cf6;"></i> RSI (14)</div>
                    <div class="indicator-value ind-buy">62.45</div>
                </div>
                <div class="indicator-row">
                    <div class="indicator-name"><i class="fas fa-arrow-trend-up" style="color: #3b82f6;"></i> EMA 50</div>
                    <div class="indicator-value ind-buy">أعلى</div>
                </div>
                <div class="indicator-row">
                    <div class="indicator-name"><i class="fas fa-arrow-trend-up" style="color: #3b82f6;"></i> EMA 200</div>
                    <div class="indicator-value ind-buy">أعلى</div>
                </div>
                <div class="indicator-row">
                    <div class="indicator-name"><i class="fas fa-water" style="color: #06b6d4;"></i> MACD</div>
                    <div class="indicator-value ind-buy">إيجابي</div>
                </div>
                <div class="indicator-row">
                    <div class="indicator-name"><i class="fas fa-layer-group" style="color: #f59e0b;"></i> Bollinger</div>
                    <div class="indicator-value ind-neutral">وسط</div>
                </div>
                <div class="indicator-row">
                    <div class="indicator-name"><i class="fas fa-compress-arrows-alt" style="color: #ec4899;"></i> Stochastic</div>
                    <div class="indicator-value ind-buy">شراء</div>
                </div>
                <div class="indicator-row">
                    <div class="indicator-name"><i class="fas fa-chart-area" style="color: #10b981;"></i> ADX</div>
                    <div class="indicator-value ind-buy">28.5 قوي</div>
                </div>
                <div class="indicator-row">
                    <div class="indicator-name"><i class="fas fa-volume-up" style="color: #f97316;"></i> Volume</div>
                    <div class="indicator-value ind-buy">مرتفع</div>
                </div>
            </div>

            <!-- Liquidity Zones -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i class="fas fa-water"></i> مناطق السيولة</div>
                </div>
                <div class="liquidity-zone">
                    <div class="zone-label"><i class="fas fa-arrow-up" style="color: var(--success);"></i> سيولة شراء</div>
                    <div class="zone-price zone-buy">2,340.20 - 2,342.50</div>
                </div>
                <div class="liquidity-zone">
                    <div class="zone-label"><i class="fas fa-arrow-down" style="color: var(--danger);"></i> سيولة بيع</div>
                    <div class="zone-price zone-sell">2,348.80 - 2,351.00</div>
                </div>
                <div class="liquidity-zone">
                    <div class="zone-label"><i class="fas fa-bullseye" style="color: var(--warning);"></i> نقطة التوازن</div>
                    <div class="zone-price" style="color: var(--warning);">2,345.00</div>
                </div>
            </div>
        </div>

        <!-- Center - Chart -->
        <div class="center-area">
            <div class="chart-container">
                <div class="chart-header">
                    <div class="chart-title">
