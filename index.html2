        </div>

        <!-- Right Sidebar -->
        <div class="sidebar-right">
            <!-- News Countdown -->
            <div class="countdown-box" id="news-countdown">
                <div class="countdown-title"><i class="fas fa-exclamation-triangle"></i> خبر هام قادم</div>
