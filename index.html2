                <div class="signal-card sell">
                    <div class="signal-badge badge-sell">بيع</div>
                    <div class="signal-timeframe">فريم 1 ساعة</div>
                    <div class="signal-price" style="color: var(--danger);">2,347.80</div>
                    <div class="signal-details">
                        <div class="detail-box">
                            <div class="detail-label">الدخول</div>
                            <div class="detail-value entry">2,347.80</div>
                        </div>
                        <div class="detail-box">
                            <div class="detail-label">وقف الخسارة</div>
                            <div class="detail-value sl">2,350.50</div>
                        </div>
                        <div class="detail-box">
                            <div class="detail-label">الهدف</div>
                            <div class="detail-value tp">2,342.00</div>
                        </div>
                    </div>
                    <div class="signal-strength">
                        <div class="strength-bar">
                            <div class="strength-fill" style="width: 78%; background: var(--danger);"></div>
                        </div>
                        <div class="strength-text" style="color: var(--danger);">78%</div>
                    </div>
                </div>

                <div class="signal-card neutral">
                    <div class="signal-badge badge-neutral">انتظار</div>
                    <div class="signal-timeframe">فريم 4 ساعات</div>
                    <div class="signal-price" style="color: var(--warning);">2,345.00</div>
                    <div class="analysis-text" style="margin-top: 10px; font-size: 12px;">
                        انتظار كسر 2,348.00 للشراء أو 2,340.00 للبيع
                    </div>
                    <div class="signal-strength">
                        <div class="strength-bar">
                            <div class="strength-fill" style="width: 50%; background: var(--warning);"></div>
                        </div>
                        <div class="strength-text" style="color: var(--warning);">50%</div>
                    </div>
                </div>
            </div>

            <!-- Economic News -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i class="fas fa-newspaper"></i> الأخبار الاقتصادية</div>
                </div>

                <div class="news-item high-impact">
                    <div class="news-time">14:30 (5 دقائق)</div>
                    <div class="news-title">مؤشر مبيعات التجزئة الأساسية الأمريكية</div>
                    <div class="news-impact impact-high">تأثير عالي</div>
                </div>

                <div class="news-item">
                    <div class="news-time">16:00</div>
                    <div class="news-title">مخزونات الجملة الأمريكية</div>
