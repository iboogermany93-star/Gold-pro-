                    </div>
                    <div class="ob-range">2,348.00 - 2,349.50</div>
                </div>

                <div class="ob-item">
                    <div class="ob-header">
                        <div class="ob-type"><i class="fas fa-arrow-up" style="color: var(--success);"></i> Bullish OB</div>
                        <div class="ob-strength">M15 - ضعيف</div>
