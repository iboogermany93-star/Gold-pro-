            <!-- Order Blocks List -->
            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i class="fas fa-cubes"></i> Order Blocks رئيسية</div>
                </div>

                <div class="ob-item">
                    <div class="ob-header">
                        <div class="ob-type"><i class="fas fa-arrow-up" style="color: var(--success);"></i> Bullish OB</div>
                        <div class="ob-strength">H4 - قوي</div>
                    </div>
                    <div class="ob-range">2,338.20 - 2,339.80</div>
                </div>

                <div class="ob-item">
                    <div class="ob-header">
                        <div class="ob-type"><i class="fas fa-arrow-down" style="color: var(--danger);"></i> Bearish OB</div>
