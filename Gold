<!DOCTYPE html>

<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>XAUUSD Pro — منصة تحليل الذهب</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<style>
:root{--gold:#FFD700;--gold2:#FFA500;--green:#00FF88;--red:#FF3355;--blue:#00CFFF;--bg:#04080F;--bg2:#080E1A;--bg3:#0D1526;--border:rgba(255,215,0,0.15);--text:#E0E8FF;--dim:#607090;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Cairo',sans-serif;overflow-x:hidden;}
.hdr{background:linear-gradient(90deg,#04080F,#0A1020,#04080F);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 18px;height:62px;position:sticky;top:0;z-index:200;}
.logo{font-family:'Orbitron',monospace;font-weight:900;font-size:1.3rem;color:var(--gold);text-shadow:0 0 18px rgba(255,215,0,.6);letter-spacing:2px;}
.logo small{display:block;font-family:'Cairo',sans-serif;font-weight:300;font-size:.7rem;color:var(--dim);letter-spacing:1px;}
.live-badge{display:flex;align-items:center;gap:5px;font-size:.65rem;color:var(--green);font-family:'Orbitron',monospace;letter-spacing:1px;}
.dot{width:7px;height:7px;border-radius:50%;background:var(--green);box-shadow:0 0 7px var(--green);animation:blink 1.4s infinite;}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.hdr-right{display:flex;flex-direction:column;align-items:flex-end;gap:3px;}
.clock{font-family:'Orbitron',monospace;font-size:1.05rem;color:var(--gold);letter-spacing:1px;}
.datestr{font-size:.68rem;color:var(--dim);}
.ticker-wrap{border-bottom:1px solid var(--border);background:var(--bg2);height:46px;overflow:hidden;}
/* HOW-TO */
.howto{background:rgba(0,207,255,.06);border:1px solid rgba(0,207,255,.3);border-radius:10px;padding:12px 16px;margin:10px;font-size:.75rem;color:var(--blue);line-height:1.8;direction:rtl;}
.howto b{color:#fff;} .howto code{background:rgba(0,0,0,.5);padding:1px 7px;border-radius:4px;font-size:.7rem;color:var(--gold);}
.close-btn{float:left;cursor:pointer;color:var(--dim);font-size:1rem;padding:0 4px;}
/* LAYOUT */
.wrap{display:grid;grid-template-columns:1fr 310px;gap:10px;padding:10px;max-width:1800px;margin:0 auto;}
.chart-box{background:var(--bg2);border:1px solid var(--border);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;}
.chart-toolbar{display:flex;align-items:center;justify-content:space-between;padding:8px 14px;background:var(--bg3);border-bottom:1px solid var(--border);}
.tf-btns{display:flex;gap:4px;}
.tf{padding:4px 11px;border:1px solid var(--border);border-radius:5px;background:transparent;color:var(--dim);font-family:'Orbitron',monospace;font-size:.65rem;cursor:pointer;transition:.2s;letter-spacing:.5px;}
.tf:hover,.tf.on{background:rgba(255,215,0,.1);border-color:var(--gold);color:var(--gold);}
.ind-tags{display:flex;gap:6px;font-size:.65rem;}
.itag{padding:2px 7px;border-radius:4px;background:rgba(255,215,0,.07);color:var(--gold2);border:1px solid rgba(255,215,0,.2);}
#tvChart{flex:1;}
.sig-strip{display:flex;gap:8px;padding:8px 10px;border-top:1px solid var(--border);background:var(--bg3);}
.sig-card{flex:1;border-radius:8px;padding:8px 12px;border:1px solid;font-size:.7rem;}
.sig-card.buy{background:rgba(0,255,136,.05);border-color:rgba(0,255,136,.3);}
.sig-card.sell{background:rgba(255,51,85,.05);border-color:rgba(255,51,85,.3);}
.sig-card.info{background:rgba(255,215,0,.04);border-color:rgba(255,215,0,.2);}
.sig-t{font-family:'Orbitron',monospace;font-size:.6rem;letter-spacing:1px;margin-bottom:3px;}
.sig-t.buy{color:var(--green)}.sig-t.sell{color:var(--red)}.sig-t.info{color:var(--gold)}
.sig-d{color:var(--dim);font-size:.65rem;line-height:1.5;}
.rr{font-family:'Orbitron',monospace;font-size:1rem;font-weight:900;text-align:center;margin-top:4px;}
/* SIDEBAR */
.sidebar{display:flex;flex-direction:column;gap:9px;}
.panel{background:var(--bg2);border:1px solid var(--border);border-radius:11px;overflow:hidden;}
.ph{padding:9px 13px;background:var(--bg3);border-bottom:1px solid var(--border);font-family:'Orbitron',monospace;font-size:.68rem;color:var(--gold);letter-spacing:1px;display:flex;align-items:center;justify-content:space-between;}
.dot2{width:5px;height:5px;border-radius:50%;background:var(--green);box-shadow:0 0 5px var(--green);animation:blink 2s infinite;}
.trades{padding:7px;display:flex;flex-direction:column;gap:5px;}
.trow{background:var(--bg3);border-radius:7px;padding:7px 9px;display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:7px;border:1px solid rgba(255,255,255,.04);font-size:.68rem;transition:.2s;}
.trow:hover{border-color:rgba(255,215,0,.2);}
.ttf{font-family:'Orbitron',monospace;font-size:.6rem;padding:2px 5px;border-radius:4px;font-weight:700;}
.ttf.buy{background:rgba(0,255,136,.15);color:var(--green);}.ttf.sell{background:rgba(255,51,85,.15);color:var(--red);}
.tep{color:var(--text);font-size:.67rem;}.tlvl{font-size:.62rem;}.tlvl .sl{color:rgba(255,51,85,.8);}.tlvl .tp{color:rgba(0,255,136,.8);}
.trr{font-family:'Orbitron',monospace;font-size:.62rem;color:var(--gold);text-align:center;}
.ana{padding:9px 12px;font-size:.68rem;line-height:1.75;direction:rtl;}
.ana p{margin-bottom:7px;}
.tag{display:inline-block;padding:1px 6px;border-radius:3px;font-size:.6rem;margin-left:3px;}
.tag.bull{background:rgba(0,255,136,.15);color:var(--green);}.tag.bear{background:rgba(255,51,85,.15);color:var(--red);}
.tag.ob{background:rgba(255,165,0,.15);color:var(--gold2);}.tag.fvg{background:rgba(0,207,255,.15);color:var(--blue);}
.tag.liq{background:rgba(255,215,0,.15);color:var(--gold);}
.news{padding:5px 7px;display:flex;flex-direction:column;gap:4px;max-height:210px;overflow-y:auto;}
.news::-webkit-scrollbar{width:3px;}.news::-webkit-scrollbar-thumb{background:var(--border);}
.ni{background:var(--bg3);border-radius:6px;padding:6px 9px;border-right:3px solid;font-size:.65rem;}
.ni.high{border-color:var(--red);}.ni.med{border-color:var(--gold2);}.ni.low{border-color:var(--dim);}
.ni.alert{animation:borderBlink 1.5s infinite;}
@keyframes borderBlink{0%,100%{opacity:1}50%{opacity:.4}}
.ntime{font-size:.62rem;color:var(--blue);margin-bottom:2px;display:flex;gap:6px;align-items:center;}
.ncnt{color:var(--red);font-weight:700;}.ntxt{color:var(--text);line-height:1.4;}.nfx{color:var(--dim);font-size:.6rem;margin-top:1px;}
.gg{padding:9px;display:grid;grid-template-columns:1fr 1fr;gap:6px;}
.gi{background:var(--bg3);border-radius:7px;padding:7px 9px;}
.gn{color:var(--dim);font-size:.6rem;margin-bottom:3px;}
.gbar{height:4px;background:rgba(255,255,255,.05);border-radius:2px;margin-bottom:3px;}
.gfill{height:100%;border-radius:2px;transition:width 1s;}
.gfill.bull{background:linear-gradient(90deg,rgba(0,255,136,.3),var(--green));}.gfill.bear{background:linear-gradient(90deg,rgba(255,51,85,.3),var(--red));}.gfill.neu{background:linear-gradient(90deg,rgba(255,215,0,.3),var(--gold));}
.gval{font-family:'Orbitron',monospace;font-size:.68rem;font-weight:700;}
.str-c{padding:8px 11px;}
.si{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid rgba(255,255,255,.04);font-size:.67rem;}
.si:last-child{border-bottom:none;}.sl2{color:var(--dim);font-size:.62rem;}.sv{font-size:.68rem;font-weight:700;}
.of{padding:8px;}
.ofr{display:grid;grid-template-columns:65px 1fr 34px;gap:6px;align-items:center;margin-bottom:5px;font-size:.65rem;}
.ofl{color:var(--dim);font-size:.6rem;}.ofbar{height:5px;background:rgba(255,255,255,.05);border-radius:3px;}.offill{height:100%;border-radius:3px;transition:width 1s;}
.ofpct{font-family:'Orbitron',monospace;font-size:.62rem;font-weight:700;}
.toast{display:none;position:fixed;bottom:18px;left:50%;transform:translateX(-50%);background:var(--bg3);border:1px solid var(--gold);border-radius:10px;padding:11px 22px;font-size:.78rem;z-index:999;text-align:center;box-shadow:0 0 25px rgba(255,215,0,.25);animation:slideUp .3s ease;max-width:480px;}
.toast.show{display:block;}
@keyframes slideUp{from{transform:translateX(-50%) translateY(16px);opacity:0}to{transform:translateX(-50%) translateY(0);opacity:1}}
@media(max-width:1100px){.wrap{grid-template-columns:1fr;}}
@media(max-width:700px){.hdr{flex-wrap:wrap;height:auto;padding:8px;gap:6px;}.clock{font-size:.85rem;}}
</style>
