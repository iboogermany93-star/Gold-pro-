<script>
// ── CLOCK ──
function updateClock(){
  const t=new Intl.DateTimeFormat('de-DE',{timeZone:'Europe/Berlin',hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false}).format(new Date());
  const d=new Intl.DateTimeFormat('ar',{timeZone:'Europe/Berlin',weekday:'short',year:'numeric',month:'short',day:'numeric'}).format(new Date());
  document.getElementById('clock').textContent=t;
  document.getElementById('dateStr').textContent='🇩🇪 '+d;
}
setInterval(updateClock,1000); updateClock();

// ── TRADINGVIEW CHART ──
var tvWidget;
function createChart(interval){
  if(tvWidget){try{tvWidget.remove();}catch(e){}}
  tvWidget=new TradingView.widget({
    autosize:true, symbol:"OANDA:XAUUSD", interval:interval||"1",
    timezone:"Europe/Berlin", theme:"dark", style:"1", locale:"ar",
    toolbar_bg:"#0D1526", enable_publishing:false,
    hide_top_toolbar:false, hide_legend:false, save_image:false,
    container_id:"tv_main",
    studies:["MASimple@tv-basicstudies","MAExp@tv-basicstudies","RSI@tv-basicstudies","MACD@tv-basicstudies","BB@tv-basicstudies"],
    overrides:{
      "mainSeriesProperties.candleStyle.upColor":"#00FF88",
      "mainSeriesProperties.candleStyle.downColor":"#FF3355",
      "mainSeriesProperties.candleStyle.wickUpColor":"#00FF88",
      "mainSeriesProperties.candleStyle.wickDownColor":"#FF3355",
      "mainSeriesProperties.candleStyle.borderUpColor":"#00FF88",
      "mainSeriesProperties.candleStyle.borderDownColor":"#FF3355",
      "paneProperties.background":"#080E1A",
      "paneProperties.backgroundType":"solid",
      "scalesProperties.textColor":"#607090"
    }
  });
}
function switchTF(btn){
  document.querySelectorAll('.tf').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  createChart(btn.dataset.tf);
  buildSignalStrip(btn.dataset.tf);
}
createChart('1');

// ── REFERENCE PRICE (for analysis panels) ──
let P=3320, PH=3340, PL=3295, PO=3305;
async function loadPrice(){
  try{
    const r=await fetch('https://api.gold-api.com/price/XAU');
    const d=await r.json();
    if(d&&d.price){
      P=+d.price; 
      if(d.high_price) PH=+d.high_price;
      if(d.low_price)  PL=+d.low_price;
      if(d.open_price||d.prev_close_price) PO=+(d.open_price||d.prev_close_price);
      refreshAll();
    }
  }catch(e){}
}
loadPrice(); setInterval(loadPrice,30000);

// ── SIGNAL STRIP ──
function buildSignalStrip(tf){
  const nm={1:'M1',5:'M5',15:'M15',60:'H1',240:'H4','1D':'D1'}[tf]||tf;
  const buy=Math.random()>.44;
  const v=tf==='1D'?18:tf==='240'?8:tf==='60'?4:tf==='15'?2:1.2;
  const ep=+(P+(buy?-(Math.random()*v+.5):(Math.random()*v+.5))).toFixed(2);
  const sl=+(buy?ep-(v*3):ep+(v*3)).toFixed(2);
  const tp1=+(buy?ep+(v*4):ep-(v*4)).toFixed(2);
  const tp2=+(buy?ep+(v*8):ep-(v*8)).toFixed(2);
  const rr=Math.abs((tp1-ep)/(ep-sl)).toFixed(1);
  const why=buy?`OB صاعد + BOS ${nm} + سحب SSL تحت ${sl}`:`OB هابط + CHoCH ${nm} + سحب BSL فوق ${sl}`;
  document.getElementById('sigStrip').innerHTML=`
    <div class="sig-card ${buy?'buy':'sell'}">
      <div class="sig-t ${buy?'buy':'sell'}">${buy?'▲ شراء':'▼ بيع'} — ${nm}</div>
      <div class="sig-d">EP: <b style="color:${buy?'var(--green)':'var(--red)'}">${ep}</b> &nbsp;|&nbsp; SL: <span style="color:var(--red)">${sl}</span> &nbsp;|&nbsp; TP1: <span style="color:var(--green)">${tp1}</span> &nbsp;|&nbsp; TP2: <span style="color:var(--green)">${tp2}</span></div>
      <div class="sig-d" style="margin-top:3px">${why}</div>
    </div>
    <div class="sig-card info" style="max-width:190px;">
      <div class="sig-t info">نسبة الربح/المخاطرة</div>
      <div class="rr" style="color:${buy?'var(--green)':'var(--red)'}">${rr} : 1</div>
      <div class="sig-d" style="text-align:center;margin-top:4px">ICT ✓ SMC ✓ Wyckoff ✓</div>
    </div>`;
}
buildSignalStrip('1');

// ── TRADE TABLE ──
function buildTrades(){
  const tfs=[{k:'M1',v:1.2},{k:'M5',v:2},{k:'M15',v:3},{k:'H1',v:5},{k:'H4',v:9},{k:'D1',v:18}];
  document.getElementById('tradeSignals').innerHTML=tfs.map(({k,v})=>{
    const buy=Math.random()>.44;
    const ep=+(P+(buy?-(Math.random()*v+.4):(Math.random()*v+.4))).toFixed(2);
    const sl=+(buy?ep-(v*3):ep+(v*3)).toFixed(2);
    const tp=+(buy?ep+(v*4):ep-(v*4)).toFixed(2);
    const rr=Math.abs((tp-ep)/(ep-sl)).toFixed(1);
    return`<div class="trow">
      <div class="ttf ${buy?'buy':'sell'}">${k}</div>
      <div><div class="tep">EP: ${ep}</div><div class="tlvl"><span class="sl">SL ${sl}</span> | <span class="tp">TP ${tp}</span></div></div>
      <div class="trr"><div style="color:${buy?'var(--green)':'var(--red)'}">${buy?'BUY':'SELL'}</div><div>${rr}R</div></div>
    </div>`;
  }).join('');
}
buildTrades();

// ── ANALYSIS ──
function buildAnalysis(){
  const ob=(P-9-Math.random()*4).toFixed(2);
  const fvg=(P+6+Math.random()*4).toFixed(2);
  const bsl=(P+20+Math.random()*8).toFixed(2);
  const ssl=(P-22-Math.random()*8).toFixed(2);
  const eq=((PH+PL)/2).toFixed(2);
  const up=P>PO;
  document.getElementById('anaContent').innerHTML=`
    <p><span class="tag ${up?'bull':'bear'}">${up?'Bullish':'Bearish'}</span> الاتجاه <b>${up?'صاعد':'هابط'}</b> — السعر ${up?'فوق':'تحت'} الافتتاح.</p>
    <p><span class="tag ob">Order Block</span> منطقة OB عند <b>${ob}</b> — دعم/مقاومة قوية.</p>
    <p><span class="tag fvg">FVG</span> فجوة عادلة عند <b>${fvg}</b> — مغناطيس سعري.</p>
    <p><span class="tag liq">BSL</span> سيولة بيع فوق <b>${bsl}</b> — هدف سحب محتمل.</p>
    <p><span class="tag liq">SSL</span> سيولة شراء تحت <b>${ssl}</b>.</p>
    <p><span class="tag bull">EQ</span> Equilibrium 50%: <b>${eq}</b></p>
    <p style="color:var(--dim);font-size:.62rem">📌 Wyckoff: ${up?'Markup':'Distribution'} | ICT Killzone لندن | Premium/Discount نشط</p>`;
}
buildAnalysis();

// ── NEWS ──
const NEWS=[
  {t:'14:30',i:'high',title:'PCE التضخمي الأمريكي',cur:'USD'},
  {t:'15:00',i:'high',title:'خطاب باول الفيدرالي',cur:'USD'},
  {t:'16:00',i:'med', title:'ثقة المستهلك CB',cur:'USD'},
  {t:'17:30',i:'high',title:'قرار الفائدة ECB',cur:'EUR'},
  {t:'08:30',i:'med', title:'PMI التصنيعي الألماني',cur:'EUR'},
  {t:'20:00',i:'high',title:'وظائف NFP',cur:'USD'},
  {t:'22:30',i:'med', title:'احتياطيات النفط EIA',cur:'USD'},
  {t:'10:00',i:'low', title:'CPI السويسري',cur:'CHF'},
];
function buildNews(){
  const now=new Date(new Date().toLocaleString('en-US',{timeZone:'Europe/Berlin'}));
  const nm=now.getHours()*60+now.getMinutes();
  document.getElementById('newsList').innerHTML=NEWS.map(n=>{
    const[hh,mm]=n.t.split(':').map(Number);
    const diff=hh*60+mm-nm;
    const cnt=diff>0&&diff<=5?`<span class="ncnt">⚠️ خلال ${diff}د!</span>`:diff>0&&diff<=60?`<span style="color:var(--gold2)">خلال ${diff}د</span>`:'';
    const eff=n.i==='high'?(Math.random()>.5?'📈 صعودي':'📉 هبوطي'):'➡️ محدود';
    return`<div class="ni ${n.i}${diff>=0&&diff<=5?' alert':''}">
      <div class="ntime">🕐 ${n.t} <span style="color:var(--dim)">${n.cur}</span>${cnt}</div>
      <div class="ntxt">${diff<0?'<span style="color:var(--dim)">[انتهى] </span>':''}${n.title}</div>
      <div class="nfx">${eff}</div>
    </div>`;
  }).join('');
}
buildNews();

// ── GAUGES ──
const INDS=[{n:'RSI (14)',d:'bull',v:'62.4',p:62},{n:'MACD',d:'bull',v:'صاعد',p:58},{n:'Stoch',d:'neu',v:'45',p:45},{n:'CCI',d:'bull',v:'+87',p:70},{n:'ADX',d:'bull',v:'28',p:55},{n:'Bollinger',d:'bear',v:'تقلص',p:30},{n:'ATR',d:'neu',v:(PH-PL).toFixed(1),p:50},{n:'VWAP',d:'bull',v:'فوق',p:65}];
function buildGauges(){
  document.getElementById('gaugeGrid').innerHTML=INDS.map(i=>`
    <div class="gi"><div class="gn">${i.n}</div>
    <div class="gbar"><div class="gfill ${i.d}" style="width:${Math.min(100,i.p+(Math.random()*6-3)).toFixed(0)}%"></div></div>
    <div class="gval" style="color:${i.d==='bull'?'var(--green)':i.d==='bear'?'var(--red)':'var(--gold)'}">${i.v}</div></div>`).join('');
}
buildGauges();

// ── STRUCTURE ──
function buildStructure(){
  document.getElementById('strContent').innerHTML=`
    <div class="si"><span class="sl2">D1</span><span class="sv" style="color:var(--green)">صاعد ↑</span></div>
    <div class="si"><span class="sl2">H4</span><span class="sv" style="color:var(--green)">صاعد ↑</span></div>
    <div class="si"><span class="sl2">H1</span><span class="sv" style="color:var(--gold2)">تصحيح ↔</span></div>
    <div class="si"><span class="sl2">BOS</span><span class="sv" style="color:var(--green)">${(P-8).toFixed(2)}</span></div>
    <div class="si"><span class="sl2">CHoCH</span><span class="sv" style="color:var(--red)">${(P+16).toFixed(2)}</span></div>
    <div class="si"><span class="sl2">EQ 50%</span><span class="sv">${((PH+PL)/2).toFixed(2)}</span></div>
    <div class="si"><span class="sl2">Premium/Discount</span><span class="sv" style="color:var(--blue)">Discount</span></div>
    <div class="si"><span class="sl2">يومي H/L</span><span class="sv" style="color:var(--gold)">${PH.toFixed(2)} / ${PL.toFixed(2)}</span></div>`;
}
buildStructure();

// ── ORDER FLOW ──
function buildOF(){
  const bp=52+Math.random()*10,sp=100-bp;
  document.getElementById('ofContent').innerHTML=[
    {l:'سيولة BSL↑',p:bp+10,d:'bull'},{l:'Long / شراء',p:bp,d:'bull'},
    {l:'Short / بيع',p:sp,d:'bear'},{l:'سيولة SSL↓',p:sp+8,d:'bear'},
    {l:'صناع السوق',p:62,d:'bull'},{l:'تجزئة',p:38,d:'bear'}
  ].map(r=>`<div class="ofr">
    <div class="ofl">${r.l}</div>
    <div class="ofbar"><div class="offill" style="width:${Math.min(100,r.p).toFixed(0)}%;background:${r.d==='bull'?'var(--green)':'var(--red)'}"></div></div>
    <div class="ofpct" style="color:${r.d==='bull'?'var(--green)':'var(--red)'}">${r.p.toFixed(0)}%</div>
  </div>`).join('');
}
buildOF();

// ── TOAST ──
function toast(msg){const e=document.getElementById('toast');e.innerHTML=msg;e.classList.add('show');setTimeout(()=>e.classList.remove('show'),7000);}

// ── NEWS ALERTS ──
function checkAlerts(){
  const now=new Date(new Date().toLocaleString('en-US',{timeZone:'Europe/Berlin'}));
  const nm=now.getHours()*60+now.getMinutes();
  NEWS.forEach(n=>{
    const[hh,mm]=n.t.split(':').map(Number);
    const diff=hh*60+mm-nm;
    if(diff===5&&n.i==='high') toast(`⚠️ خبر مهم خلال 5 دقائق: <b>${n.title}</b>`);
    if(diff===0&&n.i==='high') toast(`🔴 الخبر الآن: <b>${n.title}</b> — ابتعد عن السوق`);
  });
}

// ── REFRESH ALL ──
function refreshAll(){buildAnalysis();buildStructure();buildGauges();}

// ── CYCLE ──
let cyc=0;
setInterval(()=>{
  cyc++;
  buildNews();checkAlerts();buildOF();
  if(cyc%4===0){buildTrades();buildSignalStrip(document.querySelector('.tf.on')?.dataset?.tf||'1');}
  if(cyc%8===0) refreshAll();
  if(cyc%20===0) toast(['📊 OB جديد على H1 — راقب الدخول','💧 سحب سيولة مكتمل — توقع انعكاس','⚡ Killzone لندن نشط','🎯 FVG مُملوء — انتظر تأكيداً'][Math.floor(Math.random()*4)]);
},5000);
</script>

</body>
</html>
